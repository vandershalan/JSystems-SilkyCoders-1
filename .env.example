# Environment Variables for Sinsay AI PoC
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and should never be committed

# ============================================================================
# OpenAI / OpenRouter Configuration
# ============================================================================

# Primary API key (OpenAI SDK compatibility)
# If you use OpenRouter, you can also set OPENROUTER_API_KEY as fallback
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative: Use OpenRouter API key (fallback if OPENAI_API_KEY not set)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# OpenRouter API base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use
# Examples: openai/gpt-4o-mini, openai/gpt-4o, openai/gpt-4.1-mini
OPENROUTER_MODEL=openai/gpt-4o-mini

# ============================================================================
# Application Configuration
# ============================================================================

# Path to policy documents directory (relative to backend/ directory)
# Default: ../docs
POLICY_DOCS_PATH=../docs

# Spring Boot profile (default: dev)
# Options: dev, test, prod
SPRING_PROFILES_ACTIVE=dev

# Server port (default: 8080)
SERVER_PORT=8080

# ============================================================================
# Notes
# ============================================================================
#
# 1. API Key Fallback:
#    - If OPENAI_API_KEY is set, it will be used
#    - If OPENAI_API_KEY is NOT set, OPENROUTER_API_KEY will be used
#    - If neither is set, the application will fail to start
#
# 2. OpenRouter Configuration:
#    - Set OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#    - Set OPENROUTER_API_KEY to your OpenRouter key
#    - Set OPENROUTER_MODEL to the model you want to use (e.g., openai/gpt-4o-mini)
#
# 3. Cost Control:
#    - gpt-4o-mini is recommended for cost-effective testing
#    - Avoid gpt-4o for repeated testing to control costs
#
# 4. For Production:
#    - Never commit .env file
#    - Use environment variables or secret management
#    - Rotate keys regularly
