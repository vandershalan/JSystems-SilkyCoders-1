      "success": "#0BB407"
    },
    "background": {
      "default": "#FFFFFF",
      "light": "#EEF9FC",
      "overlay": "rgba(0, 0, 0, 0.4)"
    },
    "text": {
      "primary": "#333333",
      "secondary": "#777777",
      "muted": "#909090",
      "dark": "#16181D",
      "onDark": "#FFFFFF",
      "nav": "#303133"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "\"Euclid Circular B\", Arial, Helvetica, \"Helvetica Neue\", sans-serif",
      "cssAlias": "Euclid",
      "fallback": "Arial, Helvetica, sans-serif"
    },
    "fontWeights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSize": {
