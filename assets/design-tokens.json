    "nav": {
      "color": "#303133",
      "fontSize": "16px",
      "fontWeight": "400",
      "textDecoration": "none",
      "textTransform": "none"
    },
    "promoBar": {
      "backgroundColor": "#E90000",
      "color": "#FFFFFF",
      "fontSize": "14px",
      "fontWeight": "700"
    },
    "input": {
      "borderRadius": "34px",
      "fontSize": "14px",
      "backgroundColor": "#FFFFFF",
