    },
    "lineHeight": {
      "tight": "1.2",
      "base": "1.43",
      "relaxed": "1.5"
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px"
